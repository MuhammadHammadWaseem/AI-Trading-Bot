# ─────────────────────────────────────────────────────────────────────────────
# TRADING BOT — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ─── Binance Demo (Testnet) Credentials ───────────────────────────────────────
# Get from: https://testnet.binancefuture.com
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# ─── Binance Live (DO NOT USE IN PHASE 1) ─────────────────────────────────────
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_SECRET=

# ─── Bot Environment ──────────────────────────────────────────────────────────
# Options: testnet | live
ENVIRONMENT=testnet

# ─── Trading Pairs (comma-separated) ─────────────────────────────────────────
TRADING_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT

# ─── Default Risk Management ──────────────────────────────────────────────────
DEFAULT_LEVERAGE=10                  # Futures leverage (1-125)
DEFAULT_RISK_PER_TRADE=1.0           # % of balance to risk per trade
DEFAULT_TAKE_PROFIT_PCT=2.0          # Close trade at +2% profit
DEFAULT_STOP_LOSS_PCT=1.0            # Close trade at -1% loss
MAX_OPEN_TRADES=5                    # Max simultaneous open trades
MAX_DAILY_LOSS_PCT=5.0               # Stop trading if daily loss > 5%

# ─── AI Model Settings ────────────────────────────────────────────────────────
MODEL_RETRAIN_INTERVAL_HOURS=24      # Retrain model every 24 hours
LOOKBACK_CANDLES=100                 # Candles to look back for prediction
PREDICTION_CONFIDENCE_THRESHOLD=0.65 # Min confidence to open a trade (65%)

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=true

# ─── Database (Phase 3 - Laravel Integration) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=postgres
DB_PASSWORD=
